# =============================================================
# SERVER
# =============================================================
# Railway নিজেই PORT সেট করে — comment করে রাখুন
# PORT=3000
NODE_ENV=production

# =============================================================
# ADMIN
# =============================================================
ADMIN_EMAIL="admin@yourdomain.com"
# প্রথমবার setup এর পর মুছে ফেলুন
ADMIN_INITIAL_PASSWORD="TempPass@2025!"

# =============================================================
# DATABASE (Railway PostgreSQL)
# =============================================================
# Railway Dashboard → Variables থেকে কপি করুন
DATABASE_URL="postgresql://username:password@host:port/database_name"

# =============================================================
# APP URL
# =============================================================
APP_URL="https://postatu-production.up.railway.app"

# =============================================================
# SUPABASE
# =============================================================
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
VITE_MASTER_EMAIL="admin@yourdomain.com"

# =============================================================
# OAUTH — META (Facebook & Instagram)
# =============================================================
META_CLIENT_ID=""
META_CLIENT_SECRET=""
META_REDIRECT_URI="https://postatu-production.up.railway.app/api/auth/meta/callback"

# =============================================================
# OAUTH — YOUTUBE
# =============================================================
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
YOUTUBE_REDIRECT_URI="https://postatu-production.up.railway.app/api/auth/youtube/callback"

# =============================================================
# OAUTH — TIKTOK
# =============================================================
TIKTOK_CLIENT_ID=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_REDIRECT_URI="https://postatu-production.up.railway.app/api/auth/tiktok/callback"

# =============================================================
# SECURITY
# =============================================================
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=""
SESSION_SECRET=""

# =============================================================
# n8n AUTOMATION
# =============================================================
N8N_WEBHOOK_URL=""
# n8n থেকে আসা request verify করতে — একটি random string দিন
N8N_SECRET=""
